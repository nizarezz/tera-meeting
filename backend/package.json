{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate --schema=src/prisma/schema.prisma && tsc",
    "start": "npx prisma migrate deploy --schema=src/prisma/schema.prisma && node dist/server.js",
    "prisma:generate": "prisma generate --schema=src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=src/prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts",
    "qa:reset": "tsx prisma/qa-reset.ts",
    "demo:seed": "tsx prisma/demo-seed.ts",
    "db:probe": "node -e \"fetch('http://localhost:'+(process.env.PORT||4000)+'/health').then(r=>r.json()).then(d=>{console.log(JSON.stringify(d));process.exit(d.ok?0:1)}).catch(e=>{console.error(e.message);process.exit(1)})\"",
    "prisma:push": "prisma db push --schema=src/prisma/schema.prisma",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.1.0",
    "morgan": "^1.11.0",
    "pg-protocol": "^1.14.0",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/supertest": "^7.2.0",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
